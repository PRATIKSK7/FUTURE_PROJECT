# Environment
ENV=development

# Database (SQLAlchemy falls back to sqlite:///./copycraft.db if this is missing or empty)
DATABASE_URL=sqlite:///./copycraft.db

# Clerk Authentication Validation
CLERK_ISSUER_URL=https://clerk.placeholder.com

# External APIs
GEMINI_API_KEY=your_gemini_api_key_here

# Security
CORS_ORIGINS=http://localhost:3000
